generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  ACTIVE
  INACTIVE
  FROZEN
}

enum TransactionType {
  TRANSFER
  WITHDRAW
  DEPOSIT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum BankName {
  SBI
  ICICI
  AXIS
  HDFC
  PNB
}

model User {
  id String @id @default(uuid())
  name String
  email String? @unique
  phone String? @unique
  password String

  profilePicture String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]
  wallet Wallet?
  bankAccounts BankAccount[]
  transactionSecurity TransactionSecurity[]
}

model RefreshToken {
  id String @id @default(uuid())
  token String @unique

  userId String
  user User @relation(fields: [userId], references: [id])

  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Wallet {
  id String @id @default(uuid()) 
  balance Decimal @default(0)

  isFrozen Boolean @default(false)

  dailyLimit Decimal @default(100000)
  monthlyLimit Decimal @default(10000000)

  dailySpent Decimal @default(0)
  monthlySpent Decimal @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user User @relation(fields: [userId], references: [id])

  sentTransactions Transaction[] @relation("SentTransactions")
  receivedTransactions Transaction[] @relation("ReceivedTransactions")
}

model BankAccount {
  id String @id @default(uuid())
  balance Decimal @default(50000)
  
  bankName String
  accountHolder String
  ifscCode String
  accountNumber String @unique

  userId String
  user User @relation(fields: [userId], references: [id])

  sentTransactions     Transaction[] @relation("SentBankTransactions")
  receivedTransactions Transaction[] @relation("ReceivedBankTransactions")
}

model Transaction {
  id          String   @id @default(uuid())
  referenceId String   @unique @default(cuid())

  amount      Decimal

  type        TransactionType
  status      TransactionStatus @default(PENDING)

  senderWalletId       String?
  receiverWalletId     String?

  senderBankAccountId  String?
  receiverBankAccountId String?

  senderWallet Wallet? @relation("SentTransactions", fields: [senderWalletId], references: [id])
  receiverWallet Wallet? @relation("ReceivedTransactions", fields: [receiverWalletId], references: [id])

  senderBankAccount BankAccount? @relation("SentBankTransactions", fields: [senderBankAccountId], references: [id])
  receiverBankAccount BankAccount? @relation("ReceivedBankTransactions", fields: [receiverBankAccountId], references: [id])

  createdAt DateTime @default(now())
}

model TransactionSecurity {
  id String @id @default(uuid())

  transactionPin String?
  isPinSet Boolean @default(false)

  failedAttempts Int @default(0)
  isLocked Boolean @default(false)
  lockedUntil DateTime?

  lastPinChangedAt DateTime?

  userId String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}